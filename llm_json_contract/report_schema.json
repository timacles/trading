{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/report_schema.json",
  "title": "Market Analysis Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_date",
    "market_positioning",
    "concrete_allocation_framework"
  ],
  "properties": {
    "report_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "market_positioning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "regime",
        "directional_bias",
        "confidence",
        "short_term_view_1_5d",
        "swing_view",
        "preferred_trade_style",
        "leadership_themes",
        "reversal_themes",
        "supporting_signals",
        "conflicting_signals"
      ],
      "properties": {
        "regime": {
          "type": "string",
          "enum": ["risk_on", "risk_off", "mixed", "transitional"]
        },
        "directional_bias": {
          "type": "string",
          "enum": ["bullish", "bearish", "neutral", "mixed"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "short_term_view_1_5d": {
          "type": "string",
          "minLength": 1
        },
        "swing_view": {
          "type": "string",
          "minLength": 1
        },
        "preferred_trade_style": {
          "type": "string",
          "enum": ["momentum", "mean_reversion", "mixed"]
        },
        "leadership_themes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 7,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reversal_themes": {
          "type": "array",
          "minItems": 0,
          "maxItems": 7,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "supporting_signals": {
          "type": "array",
          "minItems": 3,
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "conflicting_signals": {
          "type": "array",
          "minItems": 0,
          "maxItems": 5,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "concrete_allocation_framework": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "net_exposure",
        "preferred_trade_types",
        "allocation_buckets"
      ],
      "properties": {
        "net_exposure": {
          "type": "string",
          "enum": [
            "net_long",
            "net_short",
            "selective_long",
            "selective_short",
            "market_neutral",
            "mixed"
          ]
        },
        "preferred_trade_types": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allocation_buckets": {
          "type": "array",
          "minItems": 3,
          "maxItems": 6,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "theme",
              "etfs",
              "direction",
              "exposure_band",
              "time_horizon",
              "setup_type",
              "evidence",
              "risk_or_invalidation"
            ],
            "properties": {
              "theme": {
                "type": "string",
                "minLength": 1
              },
              "etfs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "direction": {
                "type": "string",
                "enum": ["long", "short", "neutral"]
              },
              "exposure_band": {
                "type": "string",
                "enum": ["0-10%", "10-20%", "20-30%", "30-40%"]
              },
              "time_horizon": {
                "type": "string",
                "enum": ["1-5d", "swing"]
              },
              "setup_type": {
                "type": "string",
                "enum": ["continuation", "mean_reversion", "hedge", "watchlist"]
              },
              "evidence": {
                "type": "array",
                "minItems": 2,
                "maxItems": 4,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "risk_or_invalidation": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
